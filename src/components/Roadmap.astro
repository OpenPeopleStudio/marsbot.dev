---
// Roadmap — 3 phases, marketing-focused

type PhaseStatus = "done" | "active" | "upcoming";

interface Phase {
  id: string;
  label: string;
  title: string;
  description: string;
  items: string[];
  status: PhaseStatus;
}

const phases: Phase[] = [
  {
    id: "phase-1",
    label: "Phase 1",
    title: "Agent Foundation",
    description: "Core agent runtime, tool system, context capture, and multi-surface deployment. The infrastructure is built.",
    items: [
      "Personal AI agent runtime",
      "Multi-surface deployment (web, desktop, mobile)",
      "6 LLM providers supported",
      "Tool system with trust gates",
      "Encrypted identity vault",
      "Open People standard (spec complete)",
    ],
    status: "done",
  },
  {
    id: "phase-2",
    label: "Phase 2",
    title: "Gamified Onboarding",
    description: "First-time experience, quest system, data connectors. Making the agent useful from minute one.",
    items: [
      "Guided quest system",
      "Data source connectors",
      "Progressive capability discovery",
      "Context compounding engine",
      "First 10 beta users",
    ],
    status: "active",
  },
  {
    id: "phase-3",
    label: "Phase 3",
    title: "Structured Dataset + Export",
    description: "Personal identity graph, memory persistence, portable export. Your data becomes truly yours.",
    items: [
      "Persistent agent memory",
      "Personal identity graph",
      "Export in Open People format",
      "Cross-device continuity",
      "Public waitlist launch",
    ],
    status: "upcoming",
  },
];

const statusConfig: Record<PhaseStatus, { label: string; color: string; borderColor: string }> = {
  done: {
    label: "Done",
    color: "var(--success)",
    borderColor: "rgba(61, 187, 111, 0.25)",
  },
  active: {
    label: "In Progress",
    color: "var(--mars-orange)",
    borderColor: "rgba(232, 98, 42, 0.25)",
  },
  upcoming: {
    label: "Upcoming",
    color: "var(--text-muted)",
    borderColor: "var(--border-subtle)",
  },
};

const statusIcon: Record<PhaseStatus, string> = {
  done: `<svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
    <circle cx="8" cy="8" r="6.5" stroke="currentColor" stroke-width="1.2"/>
    <path d="M5 8l2 2 4-4" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
  </svg>`,
  active: `<svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
    <circle cx="8" cy="8" r="6.5" stroke="currentColor" stroke-width="1.2"/>
    <path d="M8 5v3.5l2 2" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
  </svg>`,
  upcoming: `<svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
    <circle cx="8" cy="8" r="6.5" stroke="currentColor" stroke-width="1.2" stroke-dasharray="2 2"/>
  </svg>`,
};
---

<section id="roadmap" class="py-20 sm:py-28 px-4 sm:px-6">
  <div class="max-w-4xl mx-auto">

    <!-- Header -->
    <div class="mb-12">
      <div class="flex items-center gap-3 mb-6">
        <span class="w-6 h-px bg-[var(--mars-orange)]"></span>
        <span class="text-[10px] font-mono text-[var(--text-muted)] uppercase tracking-[3px]">Roadmap</span>
      </div>
      <h2 class="text-2xl sm:text-3xl font-mono font-bold text-[var(--text-primary)] mb-3 tracking-tight">
        Building in the open.
      </h2>
      <p class="text-sm text-[var(--text-secondary)] max-w-xl leading-relaxed">
        Three phases from foundation to launch. Progress is real &mdash; not vaporware.
      </p>
    </div>

    <!-- Phase list -->
    <div class="space-y-4">
      {phases.map((phase) => {
        const config = statusConfig[phase.status];
        const icon = statusIcon[phase.status];
        return (
          <div
            class="bg-[var(--surface-1)] rounded-xl overflow-hidden border"
            style={`border-color: ${config.borderColor};`}
          >
            <div class="flex items-start gap-4 p-5">
              <div
                class="mt-0.5 shrink-0"
                style={`color: ${config.color};`}
                set:html={icon}
              />

              <div class="flex-1 min-w-0">
                <div class="flex items-center justify-between gap-3 mb-1 flex-wrap">
                  <div class="flex items-baseline gap-2">
                    <span class="text-xs font-mono text-[var(--text-muted)]">{phase.label}</span>
                    <h3 class="font-mono font-semibold text-[var(--text-primary)]">
                      {phase.title}
                    </h3>
                  </div>
                  <span
                    class="text-xs font-mono px-2 py-0.5 rounded shrink-0"
                    style={`color: ${config.color}; background: ${config.color}12; border: 1px solid ${config.color}30;`}
                  >
                    {config.label}
                  </span>
                </div>
                <p class="text-sm text-[var(--text-secondary)] leading-relaxed mb-4">
                  {phase.description}
                </p>

                <div class="grid sm:grid-cols-2 gap-x-6 gap-y-1.5">
                  {phase.items.map((item) => (
                    <div class="flex items-center gap-2 text-xs text-[var(--text-secondary)]">
                      <span
                        class="w-1 h-1 rounded-full shrink-0"
                        style={`background: ${phase.status === "done" ? config.color : "var(--text-muted)"};`}
                      ></span>
                      <span style={phase.status === "done" ? "" : "opacity: 0.6;"}>{item}</span>
                    </div>
                  ))}
                </div>
              </div>
            </div>

            {phase.status === "active" && (
              <div class="h-0.5 bg-[var(--border-subtle)]">
                <div
                  class="h-full"
                  style="width: 45%; background: var(--mars-orange); opacity: 0.6;"
                ></div>
              </div>
            )}

            {phase.status === "done" && (
              <div class="h-0.5" style="background: rgba(61, 187, 111, 0.3);"></div>
            )}
          </div>
        );
      })}
    </div>
  </div>
</section>
