---
// Hero section — data asymmetry framing + interactive demo island
---

<section id="hero" class="relative pt-28 sm:pt-36 pb-16 sm:pb-24 px-4 sm:px-6">
  <!-- Spatial void background -->
  <div class="absolute inset-0 bg-grid opacity-60 pointer-events-none"></div>
  <div class="absolute top-[-150px] left-1/2 -translate-x-1/2 w-[600px] h-[400px] bg-[var(--mars-orange)] opacity-[0.05] blur-[120px] rounded-full pointer-events-none"></div>
  <div class="absolute top-[100px] left-1/4 w-[300px] h-[300px] bg-[var(--mars-orange)] opacity-[0.02] blur-[100px] rounded-full pointer-events-none"></div>

  <div class="relative max-w-3xl mx-auto text-center">
    <div class="inline-flex items-center gap-2 px-2.5 py-1 rounded-md bg-[var(--surface-2)] border border-[var(--border-subtle)] text-xs font-mono text-[var(--text-muted)] mb-8 animate-fade-in">
      <span class="w-1.5 h-1.5 rounded-full bg-[var(--mars-orange)]"></span>
      beta &mdash; building in public
    </div>

    <h1 class="text-3xl sm:text-4xl md:text-5xl font-mono font-bold text-[var(--text-primary)] mb-6 animate-slide-up tracking-tight leading-tight">
      Corporations have structured data about you.<br/>
      <span class="text-[var(--mars-orange)]">Now you have one too.</span>
    </h1>

    <p class="text-base sm:text-lg text-[var(--text-secondary)] max-w-xl mx-auto mb-4 leading-relaxed animate-slide-up delay-100">
      marsbot.dev is a personal AI agent that learns your context over time &mdash; and the structured dataset it builds belongs entirely to you.
    </p>
    <p class="text-sm text-[var(--text-muted)] max-w-lg mx-auto mb-10 leading-relaxed animate-slide-up delay-200">
      Portable. Queryable. Compounding with every interaction.
    </p>

    <div class="flex items-center justify-center gap-3 animate-slide-up delay-300">
      <a href="#early-access" class="btn-primary text-sm">Join early access</a>
      <a href="#how-it-works" class="btn-secondary text-sm">See how it works</a>
    </div>
  </div>

  <!-- Interactive demo island slot -->
  <div class="relative mt-14 sm:mt-20">
    <slot />
  </div>
</section>
