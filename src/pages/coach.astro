---
import Base from "../layouts/Base.astro";
import Nav from "../components/Nav.astro";
import CoachChat from "../components/CoachChat";
---

<Base title="Coach Review — Open People Inc." description="Ask any question about the Open People Inc. project — canvas, architecture, thesis, traction.">
  <Nav />
  <main class="flex flex-col pt-14" style="height: 100vh; overflow: hidden;">

    <!-- Header -->
    <div class="shrink-0 border-b border-[var(--border-subtle)] bg-[var(--surface-1)] px-4 sm:px-6 py-2">
      <div class="max-w-4xl mx-auto flex items-center justify-between gap-3">
        <div class="flex items-center gap-2 min-w-0">
          <span class="w-1.5 h-1.5 rounded-full bg-[var(--success)] shrink-0"></span>
          <span class="text-[11px] font-mono text-[var(--text-muted)] uppercase tracking-wider whitespace-nowrap">Coach Review</span>
          <span class="text-[10px] text-[var(--text-muted)]">·</span>
          <span class="text-[10px] font-mono text-[var(--text-muted)] whitespace-nowrap">v2.0 · March 2026</span>
        </div>
        <div class="hidden sm:flex items-center gap-1.5 shrink-0">
          {["canvas", "architecture", "thesis", "traction"].map(tag => (
            <span class="text-[9px] font-mono px-2 py-0.5 rounded-full border border-[var(--border-medium)] text-[var(--text-muted)]">{tag}</span>
          ))}
        </div>
      </div>
    </div>

    <!-- Chat — fills remaining height -->
    <div class="flex-1 min-h-0 max-w-4xl mx-auto w-full relative">
      <CoachChat client:load />
    </div>

  </main>
</Base>

