---
import Base from "../layouts/Base.astro";
import Nav from "../components/Nav.astro";
import LeanerCanvas from "../components/LeanerCanvas";
---

<Base title="Lean Canvas — Open People Inc." description="Dual vision lean canvas — from personal AI agents to interplanetary data identity." ogImage="/og-canvas.png">
  <Nav />
  <main class="pt-14 min-h-screen">

    <!-- Header -->
    <div class="border-b border-[var(--border-subtle)] bg-[var(--surface-1)]">
      <div class="max-w-[1320px] mx-auto px-4 sm:px-6 py-8 sm:py-12">
        <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4">
          <div>
            <div class="flex items-center gap-2.5 mb-2">
              <!-- Inevitable Figure logo mark -->
              <svg width="18" height="23" viewBox="0 0 180 230" xmlns="http://www.w3.org/2000/svg" class="opacity-70">
                <circle cx="90" cy="32" r="20" fill="none" stroke="var(--text-primary)" stroke-width="2.2"/>
                <path d="M80 51 Q77 62, 73 76 Q68 94, 67 110 Q66 126, 68 140 Q70 152, 72 160 Q72 170, 68 182 Q62 196, 54 210" fill="none" stroke="var(--text-primary)" stroke-width="2" stroke-linecap="round"/>
                <path d="M73 78 Q62 84, 50 94 Q38 106, 30 120" fill="none" stroke="var(--text-primary)" stroke-width="1.8" stroke-linecap="round"/>
                <path d="M100 51 Q102 58, 104 66" fill="none" stroke="var(--text-primary)" stroke-width="2"/>
                <line x1="104" y1="66" x2="108" y2="86" stroke="var(--text-primary)" stroke-width="2"/>
                <line x1="108" y1="86" x2="110" y2="110" stroke="var(--text-primary)" stroke-width="1.8"/>
                <line x1="110" y1="110" x2="108" y2="140" stroke="var(--text-primary)" stroke-width="1.6"/>
                <line x1="108" y1="140" x2="104" y2="160" stroke="var(--text-primary)" stroke-width="1.6"/>
                <line x1="104" y1="160" x2="112" y2="186" stroke="var(--text-primary)" stroke-width="1.4"/>
                <line x1="112" y1="186" x2="124" y2="210" stroke="var(--text-primary)" stroke-width="1.2"/>
                <path d="M100 51 Q108 60, 118 72" fill="none" stroke="var(--text-primary)" stroke-width="1.8"/>
                <line x1="118" y1="72" x2="134" y2="86" stroke="var(--text-primary)" stroke-width="1.5"/>
                <line x1="134" y1="86" x2="146" y2="104" stroke="var(--text-primary)" stroke-width="1.3"/>
                <circle cx="104" cy="66" r="3.2" fill="var(--void)" stroke="var(--text-primary)" stroke-width="1.2"/>
                <circle cx="108" cy="86" r="3.2" fill="var(--void)" stroke="var(--text-primary)" stroke-width="1.2"/>
                <circle cx="104" cy="160" r="3.2" fill="var(--void)" stroke="var(--text-primary)" stroke-width="1.2"/>
                <circle cx="118" cy="72" r="3.2" fill="var(--void)" stroke="var(--text-primary)" stroke-width="1.2"/>
                <circle cx="134" cy="86" r="2.8" fill="var(--void)" stroke="var(--text-primary)" stroke-width="1"/>
              </svg>
              <span class="text-xs text-[var(--text-muted)] tracking-[0.1em]" style="font-family: var(--font-mono); font-weight: 300;">open people</span>
            </div>
            <h1 class="text-[var(--text-primary)] font-bold text-2xl sm:text-3xl leading-tight" style="letter-spacing: -0.5px;">
              Dual Vision Lean Canvas
            </h1>
            <p class="text-[var(--text-muted)] text-sm mt-1.5 max-w-lg">
              From personal AI agents to interplanetary data identity — two phases, one standard.
            </p>
          </div>
          <div class="hidden sm:flex flex-col items-end gap-1.5">
            <span class="text-[10px] font-mono text-[var(--text-muted)] uppercase tracking-wider">Propel Vision · Final Review</span>
            <span class="text-[10px] font-mono text-[var(--text-muted)]">March 2026</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Interactive canvas -->
    <LeanerCanvas client:load />

  </main>
</Base>
